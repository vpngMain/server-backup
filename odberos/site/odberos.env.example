# Příklad konfigurace pro systemd (Tailscale / Linux)
# Na serveru soubor vytvořte příkazy z TAILSCALE_DEPLOYMENT.md (Variant B, krok 1).
# Nebo zkopírujte jako odberos.env a nastavte SECRET_KEY (vygenerovat: python3 -c "import secrets; print(secrets.token_urlsafe(32))").
# Na serveru: chmod 600 odberos.env

SECRET_KEY=nahraďte-vygenerovaným-klíčem
FLASK_ENV=production
ALLOW_HTTP_SESSION=1
PORT=8080
